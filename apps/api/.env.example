# ─── API ─────────────────────────────────────────────────────────────────────
# Clerk JWT public key (get from Clerk Dashboard → API Keys → JWT Public Key)
# Paste the full PEM key on one line, with literal \n between lines:
# Example: -----BEGIN PUBLIC KEY-----\nMIIBIj...\n-----END PUBLIC KEY-----
JWT_PUBLIC_KEY=

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/dpin_uptime
